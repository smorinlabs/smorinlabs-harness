#!/usr/bin/env bash
# SessionStart hook for factor-harness plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-factor-harness content
using_fh_content=$(cat "${PLUGIN_ROOT}/skills/using-factor-harness/SKILL.md" 2>&1 || echo "Error reading using-factor-harness skill")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_fh_escaped=$(escape_for_json "$using_fh_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have the factor-harness plugin installed.\n\n**Below is the full content of the 'factor-harness:using-factor-harness' skill — the orienter for this bundle. factor-harness ships four skills: using-factor-harness (this one, for routing), factor-architect (architectural review pre- or post-execution), factor-scan (broad bug + quality + smell sweep), and factor-dedup (cross-implementation consolidation). Use the 'Skill' tool to invoke factor-architect, factor-scan, or factor-dedup when their triggers fire. The bundle also ships three subagents under agents/ (factor-scanner, factor-comparator, factor-researcher) that the workflow skills dispatch.**\n\n${using_fh_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI (v1.0.11+) and others expect additionalContext (top-level, SDK standard).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
